<!-- Phase-2 F250 maritime baseline derived from the PX4 Iris Gazebo Classic model. -->
<sdf version='1.6'>
  <model name='f250'>
    <link name='base_link'>
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.715</mass>
        <inertia>
          <ixx>0.003164</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.003164</iyy>
          <iyz>0</iyz>
          <izz>0.006044</izz>
