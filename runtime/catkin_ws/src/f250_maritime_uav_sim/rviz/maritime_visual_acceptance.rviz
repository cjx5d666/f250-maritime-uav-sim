  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: C Planner Cloud To EGO
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
