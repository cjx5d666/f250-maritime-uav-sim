# Optional F250 runtime overrides
# Source this from the runtime root, or replace $(pwd -P) with your runtime path.
export F250_PROJECT_ROOT="$(pwd -P)"
export F250_RUNTIME_STATE_DIR="${F250_PROJECT_ROOT}/runtime_state"
export RUN_ROOT="${F250_RUNTIME_STATE_DIR}/work"
export F250_ACTIVE_SENSOR_ENV="${F250_RUNTIME_STATE_DIR}/active_sensor.env"
export F250_ACTIVE_TASK_ENV="${F250_RUNTIME_STATE_DIR}/active_task.env"
export F250_EVIDENCE_CURRENT_DIR="${F250_PROJECT_ROOT}/evidence/current"
